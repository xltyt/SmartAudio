<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>音克隆 · 登录</title>
    <!-- Font Awesome 6 -->
    <!--
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" />
    -->
    <link rel="stylesheet" href="/css/all.min.css" />
    <!-- jQuery -->
    <script src="/js/jquery-3.7.1.min.js">
    </script>
    <style>
        /* ===== 全局 ===== */
        :root {
            --primary-start: #4F46E5;
            --primary-end: #7C3AED;
            --bg-body: #F8FAFC;
            --bg-card: rgba(255, 255, 255, 0.72);
            --border-card: rgba(255, 255, 255, 0.35);
            --shadow-card: 0 20px 35px -8px rgba(0, 0, 0, 0.10);
            --text-primary: #0F172A;
            --text-secondary: #475569;
            --text-muted: #94A3B8;
            --input-bg: rgba(255, 255, 255, 0.75);
            --input-border: #E2E8F0;
            --input-focus: #4F46E5;
            --glass-blur: blur(18px);
            --radius: 20px;
            --radius-sm: 12px;
            --font: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
            --transition: 0.25s cubic-bezier(0.22, 1, 0.36, 1);
        }
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        body {
            font-family: var(--font);
            background: var(--bg-body);
            color: var(--text-primary);
            line-height: 1.6;
            font-weight: 400;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 1.5rem;
            transition: background 0.4s ease;
        }
        body::before {
            content: '';
            position: fixed;
            top: -20%;
            right: -10%;
            width: 70vmax;
            height: 70vmax;
            background: radial-gradient(circle, rgba(79, 70, 229, 0.12) 0%, rgba(124, 58, 237, 0.04) 60%, transparent 80%);
            pointer-events: none;
            z-index: 0;
        }
        .glass {
            background: var(--bg-card);
            backdrop-filter: var(--glass-blur);
            -webkit-backdrop-filter: var(--glass-blur);
            border: 1px solid var(--border-card);
            border-radius: var(--radius);
            box-shadow: var(--shadow-card);
            transition: all var(--transition);
        }
        .glass:hover {
            box-shadow: 0 28px 45px -12px rgba(0, 0, 0, 0.18);
            /* transform: translateY(-4px); */
        }
        .login-card {
            width: 100%;
            max-width: 420px;
            padding: 2.8rem 2.4rem;
            text-align: center;
            position: relative;
            z-index: 1;
        }
        .login-card .logo-icon {
            font-size: 3.2rem;
            background: linear-gradient(135deg, var(--primary-start), var(--primary-end));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            margin-bottom: 0.2rem;
        }
        .login-card h1 {
            font-size: 1.8rem;
            font-weight: 500;
            letter-spacing: -0.02em;
            margin-bottom: 0.2rem;
        }
        .login-card .sub {
            color: var(--text-secondary);
            font-size: 0.95rem;
            margin-bottom: 2rem;
        }
        .login-card .form-group {
            text-align: left;
            margin-bottom: 1.2rem;
        }
        .login-card .form-group label {
            display: block;
            font-size: 0.85rem;
            font-weight: 500;
            color: var(--text-secondary);
            margin-bottom: 0.3rem;
        }
        .login-card .form-group input {
            width: 100%;
            padding: 0.7rem 1rem;
            border-radius: var(--radius-sm);
            border: 1.5px solid var(--input-border);
            background: var(--input-bg);
            color: var(--text-primary);
            font-size: 1rem;
            transition: border var(--transition), box-shadow var(--transition);
            outline: none;
        }
        .login-card .form-group input:focus {
            border-color: var(--input-focus);
            box-shadow: 0 0 0 4px rgba(79, 70, 229, 0.10);
        }
        .btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 0.6rem;
            padding: 0.7rem 1.8rem;
            border: none;
            border-radius: 60px;
            font-weight: 500;
            font-size: 0.95rem;
            cursor: pointer;
            transition: all var(--transition);
            background: linear-gradient(135deg, var(--primary-start), var(--primary-end));
            color: #fff;
            box-shadow: 0 4px 14px rgba(79, 70, 229, 0.25);
            width: 100%;
            margin-top: 0.6rem;
            padding: 0.8rem;
        }
        .btn:hover {
            transform: scale(1.03);
            box-shadow: 0 8px 24px rgba(79, 70, 229, 0.35);
        }
        .btn:active {
            transform: scale(0.96);
        }
        .login-error {
            color: #EF4444;
            font-size: 0.85rem;
            margin-top: 0.6rem;
            min-height: 1.5rem;
        }
        .hint {
            margin-top: 1.2rem;
            font-size: 0.78rem;
            color: var(--text-muted);
        }
    </style>
</head>
<body>

    <div class="login-card glass">
        <div class="logo-icon"><i class="fas fa-wave-square"></i></div>
        <h1>音克隆</h1>
        <p class="sub">AI 音频工坊 · 登录</p>
        <form id="loginForm" autocomplete="off" action="" method="post">
            <input type="hidden" id="method" name="method" value="login">
            <div class="form-group">
                <label for="loginUser">用户名</label>
                <input type="text" name="username" placeholder="" value="" />
            </div>
            <div class="form-group">
                <label for="loginPass">密码</label>
                <input type="password" name="passwd" placeholder="" value="" />
            </div>
            <button type="submit" class="btn"><i class="fas fa-arrow-right-to-bracket"></i> 登录</button>
            <div class="login-error" id="loginError"></div>
        </form>
        <div class="hint">
        </div>
    </div>
</body>
</html>
